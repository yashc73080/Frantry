# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Server
PORT=5000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-deployed-site.vercel.app,http://localhost:19006

# OpenRouter (free LLM for recipes + OCR parsing)
# Get a key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: override the default free model (default: meta-llama/llama-3.1-8b-instruct:free)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Google Cloud Vision API (for receipt OCR)
# Enable Vision API at https://console.cloud.google.com, then create an API key
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key

# Firebase Admin SDK — for verifying user tokens on protected routes
# TODO: [FIREBASE SETUP] Go to Firebase Console → Project Settings → Service accounts
# For local dev: download the JSON and place it at backend/serviceAccountKey.json
# For production (Railway), set these individual variables instead:
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as it appears in the JSON (with literal \n characters)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"
