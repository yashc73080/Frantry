# Backend URL
# Local: your machine's LAN IP + port 5000 (find it with `ipconfig` on Windows or `ifconfig` on Mac)
# Production: your Railway deployment URL
EXPO_PUBLIC_BACKEND_URL=http://192.168.x.x:5000

# Firebase client SDK config
# TODO: [FIREBASE SETUP] Get these values from Firebase Console → Project Settings → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Google Cloud Vision API key — now only needed on the backend (moved from frontend)
# Keep this here only if you need a fallback client-side key; otherwise remove it.
# EXPO_PUBLIC_GOOGLE_CLOUD_VISION_API_KEY=AIzaSy...
